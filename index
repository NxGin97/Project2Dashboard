<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Nutritional Insights</title>
    <!-- Tailwind CSS CDN -->
    <link
      href="https://cdn.jsdelivr.net/npm/tailwindcss@2.0.0/dist/tailwind.min.css"
      rel="stylesheet"
    />
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1"></script>
    <script src="https://cdn.jsdelivr.net/npm/chartjs-chart-matrix@2.0.0/dist/chartjs-chart-matrix.js"></script>
    <script>
      Chart.register(ChartMatrixController, MatrixElement);
    </script>
  </head>

  <body class="bg-gray-100">
    <header class="bg-blue-600 p-4 text-white">
      <h1 class="text-3xl font-semibold">Nutritional Insights</h1>
    </header>

    <main class="container mx-auto p-6">
      <section class="mb-8">
        <h2 class="text-2xl font-semibold mb-4">
          Explore Nutritional Insights
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
          <div class="bg-white p-4 shadow-lg rounded-lg">
            <h3 class="font-semibold">Bar Chart</h3>
            <p class="text-sm text-gray-600">
              Average macronutrient content by diet type.
            </p>
            <canvas id="barChart" class="w-full h-48"></canvas>
          </div>

          <div class="bg-white p-4 shadow-lg rounded-lg">
            <h3 class="font-semibold">Scatter Plot</h3>
            <p class="text-sm text-gray-600">
              Nutrient relationships (e.g., protein vs carbs).
            </p>
            <canvas id="scatterPlot" class="w-full h-48"></canvas>
          </div>

          <div class="bg-white p-4 shadow-lg rounded-lg">
            <h3 class="font-semibold">Heatmap</h3>
            <p class="text-sm text-gray-600">Nutrient correlations.</p>
            <canvas id="heatmap" height="250"></canvas>
          </div>

          <div class="bg-white p-4 shadow-lg rounded-lg">
            <h3 class="font-semibold">Pie Chart</h3>
            <p class="text-sm text-gray-600">
              Recipe distribution by diet type.
            </p>
            <canvas id="pieChart" class="w-full h-48"></canvas>
          </div>
        </div>
      </section>

      <section class="mb-8">
        <h2 class="text-2xl font-semibold mb-4">
          Filters and Data Interaction
        </h2>
        <div class="flex flex-wrap gap-4">
          <input
            type="text"
            placeholder="Search by Diet Type"
            class="p-2 border rounded w-full sm:w-auto"
          />
          <select id="dietFilter" class="p-2 border rounded w-full sm:w-auto">
            <option value="all">All Diet Types</option>
            <option value="vegan">Vegan</option>
            <option value="keto">Keto</option>
            <option value="dash">Dash</option>
            <option value="paleo">Paleo</option>
            <option value="mediterranean">Mediterranean</option>
            <!-- Add more options -->
          </select>
        </div>
      </section>

      <section class="mb-8">
        <h2 class="text-2xl font-semibold mb-4">API Data Interaction</h2>
        <div class="flex flex-wrap gap-4">
          <button
            id="loadData"
            class="bg-blue-600 text-white py-2 px-4 rounded"
          >
            Get Nutritional Insights
          </button>
          <button class="bg-green-600 text-white py-2 px-4 rounded">
            Get Recipes
          </button>
          <button class="bg-purple-600 text-white py-2 px-4 rounded">
            Get Clusters
          </button>
        </div>

        <div class="bg-white shadow rounded p-4 mt-4">
          <h3 class="font-semibold">Function Metadata</h3>

          <p>
            Execution Time:
            <span id="executionTime"> Not loaded </span>
          </p>

          <p>
            Records Processed:
            <span id="recordCount"> Not loaded </span>
          </p>
        </div>
      </section>

      <section>
        <h2 class="text-2xl font-semibold mb-4">Pagination</h2>
        <div class="flex justify-center gap-2 mt-4">
          <button class="px-3 py-1 bg-gray-300 rounded hover:bg-gray-400">
            Previous
          </button>
          <button class="px-3 py-1 bg-blue-600 text-white rounded">1</button>
          <button class="px-3 py-1 bg-gray-300 rounded hover:bg-gray-400">
            2
          </button>
          <button class="px-3 py-1 bg-gray-300 rounded hover:bg-gray-400">
            Next
          </button>
        </div>
      </section>
    </main>

    <footer class="bg-blue-600 p-4 text-white text-center mt-10">
      <p>&copy; 2025 Nutritional Insights. All Rights Reserved.</p>
    </footer>

    <script>
      document.addEventListener("DOMContentLoaded", function () {
        let barChart;
        let scatterChart;
        let pieChart;
        let heatmapChart;
				let nutritionData = [];

        document
          .getElementById("loadData")
          .addEventListener("click", async function () {
            try {
              const response = await fetch(
                "https://natp2func.azurewebsites.net/api/nutrition", //"https://natp2func.azurewebsites.net/api/nutrition" "http://localhost:7071/api/nutrition"
              );

              const data = await response.json();

              document.getElementById("executionTime").innerText =
                data.execution_time;

              document.getElementById("recordCount").innerText =
                data.records_processed;
              console.log(data);

							nutritionData = data.nutrition_data;

							const filter = document.getElementById("dietFilter");

							filter.innerHTML = '<option value="all">All Diet Types</option>';

							nutritionData.forEach(item => {

									let option = document.createElement("option");

									option.value = item.Diet_type;
									option.textContent = item.Diet_type;

									filter.appendChild(option);

							});

              /*
              -------------------------
              BAR CHART
              -------------------------
                               */

              const diets = data.nutrition_data.map((item) => item.Diet_type);

              const proteins = data.nutrition_data.map(
                (item) => item["Protein(g)"],
              );

              if (barChart) {
                barChart.destroy();
              }

              barChart = new Chart(document.getElementById("barChart"), {
                type: "bar",

                data: {
                  labels: diets,

                  datasets: [
                    {
                      label: "Average Protein (g)",
                      data: proteins,
                    },
                  ],
                },
              });

              /*
                               -------------------------
                               SCATTER PLOT
                               -------------------------
                               */

              const scatterData = data.scatter_data.map((item) => ({
                x: item["Protein(g)"],
                y: item["Carbs(g)"],
              }));

              if (scatterChart) {
                scatterChart.destroy();
              }

              scatterChart = new Chart(document.getElementById("scatterPlot"), {
                type: "scatter",

                data: {
                  datasets: [
                    {
                      label: "Protein vs Carbs",
                      data: scatterData,
                    },
                  ],
                },

                options: {
                  scales: {
                    x: {
                      title: {
                        display: true,
                        text: "Protein(g)",
                      },
                    },

                    y: {
                      title: {
                        display: true,
                        text: "Carbs(g)",
                      },
                    },
                  },
                },
              });

              /*
                               -------------------------
                               PIE CHART
                               -------------------------
                               */

              const pieLabels = data.diet_distribution.map(
                (item) => item.Diet_type,
              );

              const pieValues = data.diet_distribution.map(
                (item) => item.Count,
              );

              if (pieChart) {
                pieChart.destroy();
              }

              pieChart = new Chart(document.getElementById("pieChart"), {
                type: "pie",

                data: {
                  labels: pieLabels,

                  datasets: [
                    {
                      label: "Recipes",

                      data: pieValues,
                    },
                  ],
                },
              });

              /*
                               -------------------------
                               HEATMAP
                               -------------------------
                               */

              const heatmapData = [];

              const heatdiets = Object.keys(data.heatmap_data["Protein(g)"]);

              const nutrients = ["Protein(g)", "Carbs(g)", "Fat(g)"];

              nutrients.forEach((nutrient) => {
                heatdiets.forEach((diet) => {
                  heatmapData.push({
                    x: diet,

                    y: nutrient,

                    v: data.heatmap_data[nutrient][diet],
                  });
                });
              });

              if (heatmapChart) {
                heatmapChart.destroy();
              }

              heatmapChart = new Chart(document.getElementById("heatmap"), {
                type: "matrix",

                data: {
                  datasets: [
                    {
                      label: "Nutrition Heatmap",

                      data: heatmapData,

                      width: 50,
                      height: 50,
                      backgroundColor(context) {
                        const value = context.dataset.data[context.dataIndex].v;

                        return `rgba(0,100,255,${value / 250})`;
                      },
                    },
                  ],
                },

                options: {
                  plugins: {
                    legend: {
                      display: false,
                    },
                  },

                  scales: {
                    x: {
                      type: "category",
                      labels: heatdiets,
                    },

                    y: {
                      type: "category",
                      labels: nutrients,
                    },
                  },
                },
								
              });

              // FILTER CONTROL
              document
              .getElementById("dietFilter")
              .addEventListener("change", function(){

                  let selected = this.value;

                  let filtered;


                  if(selected == "all"){
                      filtered = nutritionData;
                  }
                  else{
                      filtered = nutritionData.filter(
                          item => item.Diet_type == selected
                      )
                  }


                  barChart.data.labels =
                      filtered.map(
                          item => item.Diet_type
                      );


                  barChart.data.datasets[0].data =
                      filtered.map(
                          item => item["Protein(g)"]
                      );


                  barChart.update();

              });


            } catch(error) {
                console.error(
                    "Error loading data:",
                    error
                );
            }

          });
      });

    </script>
  </body>
</html>
